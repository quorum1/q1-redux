---
layout: layouts/home.njk
---

<!-- ─── Hero ──────────────────────────────────────────────────────────────── -->
<section class="hero">
  <div class="hero-grid section-inner">

    <div class="hero-content">
      <span class="eyebrow hero-eyebrow">
        <span class="dot" style="width:8px;height:8px;background:var(--q-red)" aria-hidden="true"></span>
        The world's first meta-consultancy
      </span>
      <h1 class="hero-headline">
        You envision new ways of working <span class="amp">&amp;</span> organizing.<br>
        We help you make them real.
      </h1>
      <p class="hero-lead">
        Quorum1 is the connective tissue for a global community of systems&#8209;change
        organizations. One front door. Many of the best minds. All the right work.
      </p>
      <div class="hero-actions">
        <a href="/hire/" class="btn btn-primary">
          Find a partner
          <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/>
          </svg>
        </a>
        <a href="/manifesto/" class="btn btn-ghost">
          Read our manifesto
          <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <img src="/assets/images/mountain.svg" alt="Quorum1 mountain motif" />
    </div>

  </div>
</section>

<!-- ─── Logo Cloud ────────────────────────────────────────────────────────── -->
<section class="logo-cloud">
  <div class="logo-cloud-inner">
    <span class="eyebrow logo-cloud-label">
      <span class="dot" style="width:8px;height:8px;background:var(--q-yellow)" aria-hidden="true"></span>
      Woven from
    </span>
    <div class="logo-cloud-grid" aria-label="Member organizations">
      <div class="logo-tile" title="Restate Foundation">RF</div>
      <div class="logo-tile" title="Hypha">HY</div>
      <div class="logo-tile" title="Commons Engine">CE</div>
      <div class="logo-tile" title="Regen Network">RN</div>
      <div class="logo-tile" title="Dark Matter Labs">DM</div>
      <div class="logo-tile" title="BlockScience">BS</div>
      <div class="logo-tile" title="Other Internet">OI</div>
      <div class="logo-tile" title="Edgeryders">ER</div>
    </div>
    <span class="logo-cloud-more">+ 64 more</span>
  </div>
</section>

<!-- ─── What We Do ───────────────────────────────────────────────────────── -->
<section class="what-we-do">
  <div class="section-inner">

    <div class="wwd-header">
      <div>
        <span class="eyebrow wwd-eyebrow">What we do</span>
        <h2 class="wwd-title">We weave member expertise into one trusted, future&#8209;ready collective.</h2>
      </div>
      <div class="brand-chord" aria-hidden="true">
        <span class="dot" style="width:14px;height:14px;background:var(--q-red)"></span>
        <span class="dot" style="width:14px;height:14px;background:var(--q-yellow)"></span>
        <span class="dot" style="width:14px;height:14px;background:var(--q-blue)"></span>
        <span class="dot" style="width:14px;height:14px;background:var(--ink)"></span>
      </div>
    </div>

    <div class="wwd-grid">

      <article class="wwd-card">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--q-red)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
        </svg>
        <span class="eyebrow wwd-card-eyebrow">For client orgs</span>
        <h3 class="wwd-card-title">One front door.</h3>
        <p class="wwd-card-body">Brief us once. We route your project to the best-aligned practitioners in the network — governance, regenerative design, commons law, technical implementation.</p>
        <a href="/hire/" class="wwd-card-cta">
          Tell us about a project
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/>
          </svg>
        </a>
      </article>

      <article class="wwd-card">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--q-yellow-deep)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <span class="eyebrow wwd-card-eyebrow">For member firms</span>
        <h3 class="wwd-card-title">Punch above your weight.</h3>
        <p class="wwd-card-body">Solo consultancy? Boutique studio? Plug into a shared brand halo and a steady lead pipeline. Keep your independence; gain the leverage of a 70-person team.</p>
        <a href="/join/" class="wwd-card-cta">
          Apply to join
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/>
          </svg>
        </a>
      </article>

      <article class="wwd-card">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--q-blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="5" r="2"/>
          <circle cx="5" cy="19" r="2"/>
          <circle cx="19" cy="19" r="2"/>
          <line x1="12" y1="7" x2="12" y2="13"/>
          <line x1="12" y1="13" x2="6.5" y2="17.5"/>
          <line x1="12" y1="13" x2="17.5" y2="17.5"/>
        </svg>
        <span class="eyebrow wwd-card-eyebrow">For the movement</span>
        <h3 class="wwd-card-title">Compete collectively.</h3>
        <p class="wwd-card-body">Region and practice nodes pool revenue to fund sales, marketing, and research that no single member could afford alone. Twenty percent of every project flows back.</p>
        <a href="/practices/" class="wwd-card-cta">
          How nodes work
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/>
          </svg>
        </a>
      </article>

    </div>
  </div>
</section>

<!-- ─── Manifesto ─────────────────────────────────────────────────────────── -->
<section class="manifesto">
  <div class="manifesto-grid">

    <div>
      <span class="eyebrow manifesto-eyebrow" style="color:var(--q-yellow)">
        <span class="dot" style="width:8px;height:8px;background:var(--q-yellow)" aria-hidden="true"></span>
        Manifesto &middot; 01
      </span>
      <div class="brand-chord" aria-hidden="true" style="margin-top:20px">
        <span class="dot" style="width:16px;height:16px;background:var(--q-red)"></span>
        <span class="dot" style="width:16px;height:16px;background:var(--q-yellow)"></span>
        <span class="dot" style="width:16px;height:16px;background:var(--q-blue)"></span>
        <span class="dot" style="width:16px;height:16px;background:var(--paper-pure)"></span>
      </div>
    </div>

    <div>
      <p class="manifesto-quote">
        <span class="highlight">What comes next,</span> already exists.
        It is being built, quietly, by the most aligned organizations in the world —
        scattered across nodes, working under different names, on overlapping projects,
        with no shared front door.
      </p>
      <p class="manifesto-body">
        Quorum1 is that front door. We aggregate, amplify, and activate the work of
        regenerative, commons&#8209;based, and systems&#8209;change organizations — reducing
        friction in biz dev, sales, and partnerships so their ideas can reach the
        clients and projects that need them most.
      </p>
    </div>

  </div>
</section>

<!-- ─── Nodes Section ────────────────────────────────────────────────────── -->
<section class="nodes">
  <div class="nodes-grid section-inner">

    <div>
      <span class="eyebrow nodes-eyebrow">How we organize</span>
      <h2 class="nodes-title">Nodes do the work the brand can't.</h2>
      <p class="nodes-intro">
        Twenty percent of every Quorum1 project flows back to nodes — ten to a
        region node, ten to a practice node — funding the sales, marketing, and
        research that keep the collective self-sustaining.
      </p>
      <div class="nodes-tabs" role="tablist" aria-label="Node types">
        <button class="nodes-tab active" role="tab" aria-selected="true" data-panel="practice">Practice nodes</button>
        <button class="nodes-tab" role="tab" aria-selected="false" data-panel="region">Region nodes</button>
      </div>
    </div>

    <div>
      <!-- Practice panel (default visible) -->
      <div class="nodes-panel" id="panel-practice" role="tabpanel">
        <span class="nodes-panel-dot" style="background:var(--q-blue)" aria-hidden="true"></span>
        <span class="eyebrow nodes-panel-tagline">Communities of expertise.</span>
        <h3 class="nodes-panel-title">Practice nodes</h3>
        <p class="nodes-panel-body">Practice nodes are member-led collectives organized around a domain — governance design, regenerative finance, commons law, decentralized infrastructure, sense-making. Each node curates its own thought work, runs joint research, and receives 10% of every project routed through its practice.</p>
        <div class="nodes-tags">
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-blue)" aria-hidden="true"></span> Governance Design</span>
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-blue)" aria-hidden="true"></span> Regenerative Finance</span>
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-blue)" aria-hidden="true"></span> Commons Law</span>
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-blue)" aria-hidden="true"></span> Decentralized Infra</span>
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-blue)" aria-hidden="true"></span> Sense-making</span>
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-blue)" aria-hidden="true"></span> Treasury Ops</span>
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-blue)" aria-hidden="true"></span> Network Stewardship</span>
        </div>
      </div>

      <!-- Region panel (hidden by default) -->
      <div class="nodes-panel" id="panel-region" role="tabpanel" hidden>
        <span class="nodes-panel-dot" style="background:var(--q-red)" aria-hidden="true"></span>
        <span class="eyebrow nodes-panel-tagline">Geography is still real.</span>
        <h3 class="nodes-panel-title">Region nodes</h3>
        <p class="nodes-panel-body">Region nodes route work to practitioners on the ground — local language, local law, local trust. They host gatherings, brief inbound clients, and recycle 10% of project revenue into community sales &amp; marketing.</p>
        <div class="nodes-tags">
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-red)" aria-hidden="true"></span> North America</span>
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-red)" aria-hidden="true"></span> Latin America</span>
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-red)" aria-hidden="true"></span> European Union</span>
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-red)" aria-hidden="true"></span> United Kingdom</span>
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-red)" aria-hidden="true"></span> Sub-Saharan Africa</span>
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-red)" aria-hidden="true"></span> South Asia</span>
          <span class="nodes-tag"><span class="dot" style="width:6px;height:6px;background:var(--q-red)" aria-hidden="true"></span> Pacific</span>
        </div>
      </div>
    </div>

  </div>
</section>
