---
pagination:
  data: projects
  size: 1
  alias: project
permalink: "/projects/@{{ project.key }}/"
layout: layouts/page.njk
---
{% set title = project.name %}
{% set description = project.summary %}

<div class="page-header">
  <span class="eyebrow page-header-eyebrow" style="margin-bottom:12px">
    <a href="/projects/" style="color:var(--ink-mute);text-decoration:none">Projects</a>
    <span style="color:var(--ink-line)">/</span>
    @{{ project.key }}
  </span>
  <div class="page-header-top">
    <div>
      <h1 class="page-title">{{ project.name }}</h1>
    </div>
    <div class="page-header-actions">
      {% if project.isExample %}<span class="badge badge-org">Example</span>{% endif %}
      <span class="badge badge-{{ project.status }}">{{ project.status }}</span>
    </div>
  </div>
</div>

<div class="profile-layout">

  <div class="profile-main">

    {% if project.summary %}
    <div class="profile-section">
      <h2 class="profile-section-title">Summary</h2>
      <p class="profile-bio">{{ project.summary }}</p>
    </div>
    {% endif %}

    {% if project.services and project.services.length %}
    <div class="profile-section">
      <h2 class="profile-section-title">Services used</h2>
      <div class="chip-list">
        {% for s in project.services %}
        <a href="/services/@{{ s.key }}/" class="chip">{{ s.name }}</a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if project.members and project.members.length %}
    <div class="profile-section">
      <h2 class="profile-section-title">Team members</h2>
      <div class="chip-list">
        {% for m in project.members %}
        <a href="/@{{ m.key }}/" class="chip">{{ m.name }}</a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if project.orgs and project.orgs.length %}
    <div class="profile-section">
      <h2 class="profile-section-title">Organizations</h2>
      <div class="chip-list">
        {% for o in project.orgs %}
        <a href="/orgs/@{{ o.key }}/" class="chip">{{ o.name }}</a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

  </div>

  <aside class="profile-sidebar" aria-label="Project details">
    {% if project.dateCompleted %}
    <div class="sidebar-fact">
      <span class="sidebar-label">Completed</span>
      <span class="sidebar-value">{{ project.dateCompleted }}</span>
    </div>
    {% endif %}
    {% if project.nodes and project.nodes.length %}
    <div class="sidebar-fact">
      <span class="sidebar-label">Nodes involved</span>
      <span class="sidebar-value">
        {% for n in project.nodes %}
        <a href="/nodes/@{{ n.key }}/">{{ n.name }}</a>{% if not loop.last %}, {% endif %}
        {% endfor %}
      </span>
    </div>
    {% endif %}
    {% if project.tags and project.tags.length %}
    <div class="sidebar-fact">
      <span class="sidebar-label">Tags</span>
      <span class="sidebar-value">{{ project.tags | join(", ") }}</span>
    </div>
    {% endif %}
    <div class="sidebar-fact" style="border-bottom:none;padding-top:20px">
      <a href="/hire/" class="btn btn-primary" style="width:100%;justify-content:center">
        Start a similar project
        <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
      </a>
    </div>
  </aside>

</div>
